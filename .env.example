# ---------------------------------------------------------------------------
# Ledgermancy configuration. Copy to .env and fill in.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
POSTGRES_USER=ledgermancy
POSTGRES_PASSWORD=change-me-in-your-env-file
POSTGRES_DB=ledgermancy
# Host port for local psql access only. Bound to 127.0.0.1 (loopback), so it
# is NOT reachable from the network. The api/worker never use this — they
# reach the database at postgres:5432 over the compose network. The prod
# overlay removes the mapping entirely. Change it if 5433 is already taken.
POSTGRES_HOST_PORT=5433
# Used by the api/worker containers to reach the postgres service.
DATABASE_URL=postgres://ledgermancy:change-me-in-your-env-file@postgres:5432/ledgermancy?sslmode=disable

# --- Server -----------------------------------------------------------------
APP_ENV=development
HTTP_ADDR=:8080
# Origin the browser loads the frontend from (CORS + cookie settings).
FRONTEND_ORIGIN=http://localhost:5173

# --- Secrets ----------------------------------------------------------------
# 32-byte key, base64-encoded. Encrypts Plaid access tokens at rest (AES-GCM).
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Signs/derives session cookie values. Generate: openssl rand -base64 32
SESSION_SECRET=

# --- Plaid ------------------------------------------------------------------
# sandbox | development | production
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
# Comma-separated. Start with transactions only; add the others when ready.
#   transactions,investments,liabilities
PLAID_PRODUCTS=transactions
# Public URL Plaid posts webhooks to. Leave blank to disable webhooks locally.
PLAID_WEBHOOK_URL=

# --- AI provider (Anthropic Messages API-compatible) ------------------------
# Works with GLM, Claude, or any Anthropic-compatible endpoint.
# Leave AI_API_KEY blank to run with AI features disabled — the app is fully
# functional without it (categorization falls back to Plaid's categories).
AI_BASE_URL=https://api.z.ai/api/anthropic
AI_API_KEY=
AI_MODEL=glm-4.6
