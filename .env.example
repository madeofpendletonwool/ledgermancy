# ---------------------------------------------------------------------------
# Ledgermancy configuration. Copy to .env and fill in.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
POSTGRES_USER=ledgermancy
POSTGRES_PASSWORD=change-me-in-your-env-file
POSTGRES_DB=ledgermancy
# Host port for local psql access only. Bound to 127.0.0.1 (loopback), so it
# is NOT reachable from the network. The api/worker never use this — they
# reach the database at postgres:5432 over the compose network. The prod
# overlay removes the mapping entirely. Change it if 5433 is already taken.
POSTGRES_HOST_PORT=5433
# Used by the api/worker containers to reach the postgres service.
DATABASE_URL=postgres://ledgermancy:change-me-in-your-env-file@postgres:5432/ledgermancy?sslmode=disable

# --- Server -----------------------------------------------------------------
APP_ENV=development
HTTP_ADDR=:8080
# Origin the browser loads the frontend from (CORS + cookie settings).
FRONTEND_ORIGIN=http://localhost:5173

# Host port the frontend (nginx) container publishes. It serves the built UI
# and proxies /api and /webhooks to the api over the internal network. In
# production this is the port your TLS-terminating reverse proxy forwards to.
FRONTEND_HOST_PORT=8081

# Loopback host port for the api, used ONLY in local development (the vite dev
# server proxies /api here). The prod overlay removes the api's host port
# entirely, so this has no effect in production.
API_HOST_PORT=8080

# Whether to believe X-Forwarded-For / X-Forwarded-Proto on incoming requests.
#
# Leave this false here. The prod overlay sets it to true for you, and it is
# only safe there: that overlay removes the api's host port entirely, so the
# bundled nginx — which strips client-supplied address headers — is the only
# way in.
#
# Turning it on without a sanitising proxy in front lets any caller choose its
# own apparent IP address, which defeats every per-IP rate limit and poisons
# the security audit log. Leaving it off when there IS such a proxy is merely
# lossy: every request looks like it came from the proxy.
TRUST_PROXY_HEADERS=false

# Which reverse proxies in front of the bundled nginx are allowed to tell it
# who the client is. Comma- or space-separated IPs and/or CIDR ranges.
#
# Leave this EMPTY if nothing sits in front of the frontend container — it is
# then the edge, it already sees real client addresses, and naming anything
# here would let that thing forge them.
#
# Set it if you run the documented production topology, where a separate
# TLS-terminating proxy forwards to FRONTEND_HOST_PORT. Every connection then
# arrives from that proxy's address, and unless it is listed here the api sees
# one IP for the entire internet: per-IP rate limits collapse into a single
# shared bucket (one bot probing the login endpoint locks out every real user)
# and the audit log records the proxy on every event.
#
# Only connections *from* these addresses get their X-Forwarded-For believed.
# Anything else reaching the container directly is still pinned to its true
# address, so publishing the port stays safe.
#
#   TRUSTED_PROXIES=10.0.0.4
#   TRUSTED_PROXIES=10.0.0.4,172.18.0.0/16
TRUSTED_PROXIES=

# --- Secrets ----------------------------------------------------------------
# 32-byte key, base64-encoded. Encrypts Plaid access tokens at rest (AES-GCM).
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# Signs/derives session cookie values. Generate: openssl rand -base64 32
SESSION_SECRET=

# --- Plaid ------------------------------------------------------------------
# sandbox | development | production
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
# Comma-separated. Start with transactions only; add the others when ready.
#   transactions,investments,liabilities
PLAID_PRODUCTS=transactions
# Public URL Plaid posts webhooks to. Leave blank to disable webhooks locally.
PLAID_WEBHOOK_URL=

# --- AI provider (Anthropic Messages API-compatible) ------------------------
# Works with GLM, Claude, or any Anthropic-compatible endpoint.
# Leave AI_API_KEY blank to run with AI features disabled — the app is fully
# functional without it (categorization falls back to Plaid's categories).
AI_BASE_URL=https://api.z.ai/api/anthropic
AI_API_KEY=
AI_MODEL=glm-4.6
